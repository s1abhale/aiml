   "source": [
    "def fibonacci_series(n):\n",
    "\n",
    "    fib= [0, 1] \n",
    "    for i in range(2, n): \n",
    "        fib.append(fib[i-1] + fib[i-2]) \n",
    "    return fib\n",
    "print(fibonacci_series(10)) "
   ]
